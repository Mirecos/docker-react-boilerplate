# Frontend
LOCAL_API_BASE_URL="http://localhost:8080/"
REACT_APP_LOCAL_API_BASE_URL="http://localhost:8080/"

# Api
HOSTNAME="0.0.0.0"
PORT=8080
JWT_SECRET="ThisIsASecretKey"
TOKEN_EXPIRATION_DAYS=7
ROOT_USER_EMAIL="root@example.com"
ROOT_USER_PASSWORD="root"

# Database
POSTGRES_DB="db"
POSTGRES_USER="user"
POSTGRES_PASSWORD="pwd"

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/connection-strings
# Common
DATABASE_URL="postgresql://user:pwd@database:5432/db"